			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1720670910441</Id>
					<Name><![CDATA[queuetime]]></Name>
					<X>-230</X><Y>430</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[finalqueue= new ArrayList<Double>();
totaltime=0;
for (int i = 0; i < exitlist.size(); i++) {
       finalqueue.add(exitlist.get(i) - enterlist.get(i));
     }
for (int j=0;j<finalqueue.size();j++){
       totaltime += finalqueue.get(j);
       }
meantime = totaltime/finalqueue.size();]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1721282189378</Id>
					<Name><![CDATA[idletime]]></Name>
					<X>-420</X><Y>540</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[totalsertime=0;
if(k==0){

for (int i = 0; i < serviceexitlist.size(); i++) {
       finalservice.add(serviceexitlist.get(i) -serviceenterlist.get(i));
       h++;
     }
}
else{
n =0;
for (int i = h; i < serviceexitlist.size(); i++) {
       finalservice.add(serviceexitlist.get(i) -serviceenterlist.get(i));
       n++;
     }
}
for(int i =0; i<finalservice.size();i++){
	totalsertime+=finalservice.get(i);
}
h+=n;
k++;     
totalidletime=numofgate*(k)*10-totalsertime;
meanidleper = (100*totalidletime)/(numofgate*k*10);]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1721338032675</Id>
					<Name><![CDATA[meanWaitTime]]></Name>
					<X>-340</X><Y>830</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[int excludeNum = enterlist.size()-exitlist.size();
Collection<Double> values=treeMapWait.values();
List<Double> sortedValues = new ArrayList<Double>(values);
sortedValues.sort(Comparator.reverseOrder());
double totalwait = 0;
for (int i = excludeNum; i < sortedValues.size(); i++) {
totalwait += sortedValues.get(i);
}
meanwait = totalwait/exitlist.size();]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1721338032677</Id>
					<Name><![CDATA[idlePercentage]]></Name>
					<X>-340</X><Y>860</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[numofgate=services.getQueues().size();
int excludeNum2 = serviceenterlist.size()-serviceexitlist.size();
Collection<Double> values2 =treeMapServ.values();
List<Double> sortedValues2 = new ArrayList<Double>(values2);
sortedValues2.sort(Comparator.reverseOrder());
double totalserv = 0;
for (int i = excludeNum2; i < sortedValues2.size(); i++) {
totalserv += sortedValues2.get(i);
}
idleper = 100*(1-totalserv/(time()*numofgate));]]></Body>
				</Function>
			</Functions>
